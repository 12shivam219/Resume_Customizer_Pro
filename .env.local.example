# Local PostgreSQL Database Configuration
# Use this if you want to run PostgreSQL locally instead of Neon

# Install PostgreSQL locally, then use:
DATABASE_URL=postgresql://postgres:password@localhost:5432/resume_customizer

# Or use Docker:
# docker run --name postgres-resume -e POSTGRES_PASSWORD=password -e POSTGRES_DB=resume_customizer -p 5432:5432 -d postgres:15

# Then run migrations:
# npm run db:push
